---
import "../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const anchor = (id: string) => `${base}#${id}`;
const placeholder = (file: string) => `${base}placeholders/${file}`;
const photo = (file: string) => `${base}photos/${file}`;
const handle = "@lyubmyr_rudko";
const handleSlug = handle.slice(1);
const profileUrl = `https://github.com/${handleSlug}`;
const linkedInUrl = "https://www.linkedin.com/in/lrudko/";
const telegramUrl = "https://t.me/lyubomyr_rudko_work";
const youtubeUrl = `https://www.youtube.com/${handle}`;

const navItems = [
  { label: "About", href: anchor("about") },
  { label: "Software Development", href: anchor("software-development") },
  { label: "Portfolio", href: anchor("projects") },
  { label: "Blog", href: anchor("blog") },
  { label: "CV", href: `${base}cv/` },
  { label: "Contact", href: anchor("contact") },
];

const socialLinks = [
  { label: "LinkedIn", href: linkedInUrl },
  { label: "YouTube", href: youtubeUrl },
  { label: "Profile", href: profileUrl },
];

const stats = [
  { index: "01", value: "Build", label: "Software Development" },
  { index: "02", value: "Ship", label: "Product Engineering" },
  { index: "03", value: "Hire", label: handle },
];

const developmentServices = [
  {
    title: "Software Development",
    text: "End-to-end implementation for websites, apps, and product features",
  },
  {
    title: "Frontend Engineering",
    text: "Responsive, maintainable interfaces built with modern web tooling",
  },
  {
    title: "Technical Delivery",
    text: "Practical planning, architecture, and execution support",
  },
];

const topics = [
  "Software Development",
  "Product Engineering",
  "Technical Strategy",
  "Delivery Systems",
  "Frontend Architecture",
  "Developer Experience",
];

const projects = [
  {
    index: "01",
    title: "Portfolio",
    subtitle: handle,
    description:
      "A placeholder project card for the portfolio homepage and selected work that will be added as the site evolves.",
    image: placeholder("square.svg"),
    href: profileUrl,
  },
  {
    index: "02",
    title: "Engineering Notes",
    subtitle: handle,
    description:
      "A placeholder space for writing about software engineering, product development, and practical technical decisions.",
    image: placeholder("square.svg"),
    href: profileUrl,
  },
  {
    index: "03",
    title: "Open Source",
    subtitle: handle,
    description:
      "A placeholder collection for public code, experiments, and small tools that support daily engineering work.",
    image: placeholder("square.svg"),
    href: profileUrl,
  },
  {
    index: "04",
    title: "Technical Writing",
    subtitle: handle,
    description:
      "A placeholder section for essays, research notes, and long-form material connected to software delivery.",
    image: placeholder("square.svg"),
    href: profileUrl,
  },
  {
    index: "05",
    title: "Community",
    subtitle: handle,
    description:
      "A placeholder card for future collaborations, public updates, and software development work.",
    image: placeholder("square.svg"),
    href: profileUrl,
  },
];

const articles = [
  {
    title: "Building a Portfolio with Astro",
    date: "Draft",
    description: `A placeholder article from ${handle}.`,
    href: profileUrl,
  },
  {
    title: "Notes on Technical Direction",
    date: "Draft",
    description: `A placeholder article from ${handle}.`,
    href: profileUrl,
  },
  {
    title: "Shipping Maintainable Frontends",
    date: "Draft",
    description: `A placeholder article from ${handle}.`,
    href: profileUrl,
  },
];

const contactLinks = [
  { label: "GitHub", handle, href: profileUrl },
  { label: "LinkedIn", handle, href: linkedInUrl },
  { label: "YouTube", handle, href: youtubeUrl },
  { label: "Profile", handle, href: profileUrl },
];

const footerSocialLinks = [
  { label: "Telegram", href: telegramUrl, icon: "telegram" },
  { label: "LinkedIn", href: linkedInUrl, icon: "linkedin" },
];
---

<!doctype html>
<html lang="en" class="bg-background">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content={`Hire Lyubomyr Rudko for software development. Portfolio, projects, writing, and public links for ${handle}.`}
    />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>Lyubomyr Rudko - Software Development Portfolio</title>
  </head>
  <body class="bg-background font-sans text-foreground antialiased">
    <main class="min-h-screen bg-background">
      <header
        class="fixed inset-x-0 top-0 z-50 border-b border-border bg-background/95 backdrop-blur-sm"
      >
        <div class="mx-auto max-w-7xl px-6 lg:px-12">
          <div
            class="flex min-h-20 flex-col gap-4 py-4 md:flex-row md:items-center md:justify-between md:gap-8"
          >
            <a
              class="text-lg font-medium tracking-tight text-foreground"
              href={base}
            >
              Lyubomyr Rudko
            </a>

            <nav
              aria-label="Primary navigation"
              class="flex gap-6 overflow-x-auto pb-1 text-sm md:gap-10 md:overflow-visible md:pb-0"
            >
              {
                navItems.map((item) => (
                  <a
                    class="shrink-0 text-muted-foreground transition-colors hover:text-foreground"
                    href={item.href}
                  >
                    {item.label}
                  </a>
                ))
              }
            </nav>
          </div>
        </div>
      </header>

      <section class="flex min-h-screen items-center pt-32 md:pt-20">
        <div class="mx-auto w-full max-w-7xl px-6 py-20 lg:px-12">
          <div class="grid items-center gap-12 lg:grid-cols-12 lg:gap-8">
            <div class="space-y-8 lg:col-span-7">
              <div class="space-y-6">
                <p
                  class="text-sm uppercase tracking-widest text-muted-foreground"
                >
                  Software Development Portfolio
                </p>
                <h1
                  class="text-5xl font-medium leading-[1.05] tracking-tight text-foreground md:text-6xl lg:text-7xl xl:text-8xl"
                >
                  Lyubomyr<br />Rudko
                </h1>
              </div>

              <p
                class="max-w-xl text-lg leading-relaxed text-muted-foreground md:text-xl"
              >
                Hire Lyubomyr Rudko for software development, product
                engineering, and practical technical delivery. Get in touch
                through {handle}.
              </p>

              <div class="flex flex-col gap-4 pt-4 sm:flex-row">
                <a
                  class="inline-flex items-center justify-center gap-2 rounded-full bg-primary px-8 py-4 font-medium text-primary-foreground transition-opacity hover:opacity-90"
                  href={anchor("contact")}
                >
                  Get in Touch
                  <svg
                    aria-hidden="true"
                    class="h-[18px] w-[18px]"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M5 12h14"></path>
                    <path d="m12 5 7 7-7 7"></path>
                  </svg>
                </a>
                <a
                  class="inline-flex items-center justify-center gap-2 rounded-full border border-border px-8 py-4 font-medium transition-colors hover:bg-secondary"
                  href={profileUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Hire {handle}
                </a>
              </div>

              <div class="flex items-center gap-4 pt-4">
                {
                  socialLinks.map((link) => (
                    <a
                      target="_blank"
                      rel="noopener noreferrer"
                      class="rounded-full border border-border px-4 py-3 text-sm text-muted-foreground transition-all hover:border-foreground hover:text-foreground"
                      aria-label={`${link.label} ${handle}`}
                      href={link.href}
                    >
                      {handle}
                    </a>
                  ))
                }
              </div>
            </div>

            <div class="lg:col-span-5">
              <div class="relative">
                <div
                  class="relative aspect-[4/5] overflow-hidden rounded-2xl bg-secondary"
                >
                  <img
                    alt="Lyubomyr Rudko"
                    class="absolute inset-0 h-full w-full object-cover"
                    decoding="async"
                    src={photo("lyubomyr_rudko_photo.jpg")}
                  />
                </div>
                <div
                  class="absolute -bottom-6 -left-4 rounded-xl border border-border bg-background px-6 py-4 shadow-sm sm:-left-6"
                >
                  <p class="text-sm text-muted-foreground">Currently</p>
                  <p class="font-medium text-foreground">{handle}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="about" class="border-t border-border py-20">
        <div class="mx-auto max-w-7xl px-6 lg:px-12">
          <div class="grid gap-16 lg:grid-cols-12">
            <div class="lg:col-span-5">
              <p
                class="mb-4 text-sm uppercase tracking-widest text-muted-foreground"
              >
                About
              </p>
              <h2
                class="mb-10 text-4xl font-medium tracking-tight text-foreground md:text-5xl"
              >
                Background
              </h2>
              <div
                class="relative aspect-[4/3] overflow-hidden rounded-2xl bg-secondary"
              >
                <img
                  alt="Placeholder background image"
                  class="absolute inset-0 h-full w-full object-cover"
                  loading="lazy"
                  decoding="async"
                  src={placeholder("landscape.svg")}
                />
              </div>
            </div>

            <div class="space-y-8 lg:col-span-7">
              <p
                class="text-lg leading-relaxed text-muted-foreground md:text-xl"
              >
                Lyubomyr Rudko works across software development, product
                engineering, and technical delivery. This portfolio is set up as
                a clear foundation for services, selected work, and writing.
              </p>
              <p
                class="text-lg leading-relaxed text-muted-foreground md:text-xl"
              >
                Public links and future updates should point to
                <span class="text-foreground"> {handle}</span>, keeping the site
                ready for real content without carrying over imported placeholder
                names or references.
              </p>

              <div
                class="mt-12 grid grid-cols-1 gap-6 border-t border-border pt-12 sm:grid-cols-3"
              >
                {
                  stats.map((stat) => (
                    <div class="space-y-2">
                      <div class="flex items-baseline gap-2">
                        <span class="text-xs text-muted-foreground">
                          {stat.index}
                        </span>
                        <span class="text-3xl font-medium text-foreground md:text-4xl">
                          {stat.value}
                        </span>
                      </div>
                      <p class="text-sm text-muted-foreground">{stat.label}</p>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="software-development" class="bg-secondary py-20">
        <div class="mx-auto max-w-7xl px-6 lg:px-12">
          <div class="grid gap-16 lg:grid-cols-12">
            <div class="lg:col-span-5">
              <p
                class="mb-4 text-sm uppercase tracking-widest text-muted-foreground"
              >
                Software Development
              </p>
              <h2
                class="mb-8 text-4xl font-medium tracking-tight text-foreground md:text-5xl"
              >
                Hire Lyubomyr
              </h2>
              <p class="mb-12 text-lg leading-relaxed text-muted-foreground">
                Get in touch to hire {handle} for software development,
                frontend implementation, product engineering, and practical
                delivery support.
              </p>

              <div class="space-y-6">
                {
                  developmentServices.map((service) => (
                    <div class="flex items-start gap-4">
                      <div class="rounded-full border border-border bg-background p-3">
                        <svg
                          aria-hidden="true"
                          class="h-5 w-5 text-foreground"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                          <circle cx="9" cy="7" r="4" />
                          <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                          <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                        </svg>
                      </div>
                      <div>
                        <h3 class="font-medium text-foreground">
                          {service.title}
                        </h3>
                        <p class="text-sm text-muted-foreground">
                          {service.text}
                        </p>
                      </div>
                    </div>
                  ))
                }
              </div>
            </div>

            <div class="lg:col-span-7">
              <div class="rounded-2xl border border-border bg-background p-10">
                <h3 class="mb-8 text-xl font-medium text-foreground">
                  Topic Areas
                </h3>
                <div class="mb-8 flex flex-wrap gap-3">
                  {
                    topics.map((topic) => (
                      <span class="rounded-full border border-border px-5 py-2.5 text-sm text-foreground transition-colors hover:border-foreground">
                        {topic}
                      </span>
                    ))
                  }
                </div>
                <a
                  class="inline-flex items-center gap-2 text-foreground underline-offset-4 hover:underline"
                  href={anchor("contact")}
                >
                  Get in touch to hire {handle}
                  <svg
                    aria-hidden="true"
                    class="h-4 w-4"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M7 7h10v10"></path>
                    <path d="M7 17 17 7"></path>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="projects" class="bg-secondary py-20">
        <div class="mx-auto max-w-7xl px-6 lg:px-12">
          <div class="mb-16">
            <p
              class="mb-4 text-sm uppercase tracking-widest text-muted-foreground"
            >
              Portfolio
            </p>
            <h2
              class="text-4xl font-medium tracking-tight text-foreground md:text-5xl"
            >
              My Portfolio
            </h2>
          </div>

          <div class="space-y-4">
            {
              projects.map((project) => (
                <a
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block rounded-2xl border border-border bg-background p-8 transition-all duration-300 hover:border-foreground"
                  href={project.href}
                >
                  <div class="flex flex-col gap-6 md:flex-row md:items-start">
                    <div class="flex items-center gap-4">
                      <span class="font-mono text-sm text-muted-foreground">
                        {project.index}
                      </span>
                      <div class="flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-xl">
                        <img
                          alt="Placeholder project graphic"
                          class="h-full w-full object-cover"
                          loading="lazy"
                          decoding="async"
                          src={project.image}
                        />
                      </div>
                    </div>
                    <div class="flex-1 space-y-3">
                      <div class="flex items-start justify-between gap-4">
                        <div>
                          <h3 class="text-2xl font-medium text-foreground underline-offset-4 group-hover:underline">
                            {project.title}
                          </h3>
                          <p class="mt-1 text-sm text-muted-foreground">
                            {project.subtitle}
                          </p>
                        </div>
                        <svg
                          aria-hidden="true"
                          class="h-5 w-5 shrink-0 text-muted-foreground transition-all group-hover:-translate-y-1 group-hover:translate-x-1 group-hover:text-foreground"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path d="M7 7h10v10"></path>
                          <path d="M7 17 17 7"></path>
                        </svg>
                      </div>
                      <p class="max-w-2xl text-muted-foreground">
                        {project.description}
                      </p>
                    </div>
                  </div>
                </a>
              ))
            }
          </div>
        </div>
      </section>

      <section id="blog" class="border-t border-border py-20">
        <div class="mx-auto max-w-7xl px-6 lg:px-12">
          <div
            class="mb-16 flex flex-col gap-8 md:flex-row md:items-end md:justify-between"
          >
            <div>
              <p
                class="mb-4 text-sm uppercase tracking-widest text-muted-foreground"
              >
                Blog
              </p>
              <h2
                class="text-4xl font-medium tracking-tight text-foreground md:text-5xl"
              >
                Latest Articles
              </h2>
            </div>
            <a
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-medium text-primary-foreground transition-opacity hover:opacity-90"
              href={profileUrl}
            >
              Follow {handle}
              <svg
                aria-hidden="true"
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M7 7h10v10"></path>
                <path d="M7 17 17 7"></path>
              </svg>
            </a>
          </div>

          <div class="grid gap-6 md:grid-cols-3">
            {
              articles.map((article) => (
                <a
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block rounded-2xl border border-border p-8 transition-all duration-300 hover:border-foreground"
                  href={article.href}
                >
                  <div class="mb-4 flex items-center gap-2 text-sm text-muted-foreground">
                    <span>{article.date}</span>
                  </div>
                  <h3 class="mb-3 line-clamp-2 text-xl font-medium text-foreground underline-offset-4 group-hover:underline">
                    {article.title}
                  </h3>
                  <p class="line-clamp-3 text-sm text-muted-foreground">
                    {article.description}
                  </p>
                </a>
              ))
            }
          </div>

          <div class="mt-12 text-center">
            <a
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-foreground underline-offset-4 hover:underline"
              href={profileUrl}
            >
              Open {handle}
              <svg
                aria-hidden="true"
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M7 7h10v10"></path>
                <path d="M7 17 17 7"></path>
              </svg>
            </a>
          </div>
        </div>
      </section>

      <section id="contact" class="border-t border-border py-20">
        <div class="mx-auto max-w-7xl px-6 lg:px-12">
          <div class="grid gap-16 lg:grid-cols-12">
            <div class="lg:col-span-5">
              <p
                class="mb-4 text-sm uppercase tracking-widest text-muted-foreground"
              >
                Contact
              </p>
              <h2
                class="mb-8 text-4xl font-medium tracking-tight text-foreground md:text-5xl"
              >
                Get in Touch and Hire
              </h2>
              <p class="mb-8 text-lg leading-relaxed text-muted-foreground">
                Hire Lyubomyr Rudko for software development work, product
                engineering, and frontend delivery. Public references and
                outbound links point to {handle}.
              </p>
              <a
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-full bg-primary px-8 py-4 font-medium text-primary-foreground transition-opacity hover:opacity-90"
                href={profileUrl}
              >
                Hire {handle}
                <svg
                  aria-hidden="true"
                  class="h-[18px] w-[18px]"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M7 7h10v10"></path>
                  <path d="M7 17 17 7"></path>
                </svg>
              </a>
            </div>

            <div class="lg:col-span-7">
              <h3
                class="mb-8 text-sm uppercase tracking-widest text-muted-foreground"
              >
                Find Me Online
              </h3>
              <div class="space-y-2">
                {
                  contactLinks.map((link) => (
                    <a
                      target="_blank"
                      rel="noopener noreferrer"
                      class="group flex items-center justify-between rounded-xl border border-border p-6 transition-all hover:border-foreground"
                      href={link.href}
                    >
                      <div>
                        <p class="font-medium text-foreground">{link.label}</p>
                        <p class="text-sm text-muted-foreground">
                          {link.handle}
                        </p>
                      </div>
                      <svg
                        aria-hidden="true"
                        class="h-5 w-5 text-muted-foreground transition-all group-hover:-translate-y-1 group-hover:translate-x-1 group-hover:text-foreground"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M7 7h10v10"></path>
                        <path d="M7 17 17 7"></path>
                      </svg>
                    </a>
                  ))
                }
              </div>
            </div>
          </div>

          <footer class="mt-32 border-t border-border pt-8">
            <div
              class="flex flex-col items-center justify-between gap-4 text-sm text-muted-foreground md:flex-row"
            >
              <p>&copy; 2026 Lyubomyr Rudko</p>
              <ul class="flex items-center gap-3" aria-label="Social links">
                {
                  footerSocialLinks.map((link) => (
                    <li>
                      <a
                        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-border text-muted-foreground transition-all hover:border-foreground hover:text-foreground"
                        href={link.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={link.label}
                        title={link.label}
                      >
                        {link.icon === "telegram" && (
                          <svg
                            aria-hidden="true"
                            class="h-5 w-5"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                          >
                            <path d="M21.9 4.6 18.6 20c-.2 1-.8 1.2-1.6.8l-4.8-3.6-2.3 2.2c-.3.3-.5.5-1 .5l.3-4.9 8.9-8c.4-.3-.1-.5-.6-.2L6.5 13.7 1.8 12.2c-1-.3-1-1 .2-1.5L20.4 3.6c.8-.3 1.6.2 1.5 1Z" />
                          </svg>
                        )}
                        {link.icon === "linkedin" && (
                          <svg
                            aria-hidden="true"
                            class="h-5 w-5"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          >
                            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                            <rect width="4" height="12" x="2" y="9" />
                            <circle cx="4" cy="4" r="2" />
                          </svg>
                        )}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          </footer>
        </div>
      </section>
    </main>
  </body>
</html>
